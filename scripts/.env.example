# Brand library seeding — copy this file to scripts/.env and fill in.
# scripts/.env is gitignored. NEVER commit a populated .env.

# Brandfetch API key. Required for Phase 2 (brandfetch-claimed seeding).
# Get a key at https://brandfetch.com.
# If you only want to seed manual brands, you can omit this and run with
# --no-brandfetch.
BRANDFETCH_API_KEY=your_key_here
