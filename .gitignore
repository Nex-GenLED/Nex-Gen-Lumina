# Firebase
.firebaserc

# Secrets - NEVER commit these
**/google-services.json
**/GoogleService-Info.plist
.env
.env.*
*.keystore
*service-account*.json
*firebase-adminsdk*.json
**/key.properties

# Bridge firmware secrets — config.h files contain real credentials.
# Use config.h.example as the committed template.
esp32-bridge/src/config.h
esp32-mqtt-bridge/src/config.h

# PlatformIO build outputs (any firmware tree)
**/.pio/

# One-off destructive admin scripts — never commit
scripts/wipe_controllers.js
scripts/fix_bridge_email.js
scripts/cleanup_schedules.js
scripts/enforce_schedule_limit.js
scripts/reset_all_bridge_records.js
scripts/clear_bridge_data.js
scripts/clear_bridge_state.js
scripts/wipe_customer_data.js
scripts/_cleanup_failed_customer.js

# Catalog seeder — run once to seed the canonical SKU list, then forget.
# Per Tyler's request, kept out of source control to discourage re-runs.
scripts/seed_product_catalog.js

# Wipe audit logs — outputs of wipe_customer_data.js. Archived to ~/.claude memory dir.
wipe_*.json
wipe_dryrun_*.json

# Brand library seeder secrets (script + JSON are committed; only .env isn't)
scripts/.env
# .env.example is a safe template — exempt it from the broader .env.* rule above
!scripts/.env.example

# Claude Code temp files
tmpclaude-*
.claude/

# Dreamflow
.dreamflow

# Misc temp files
nul
*.tmp
**/wled_config.json

# Cloud Functions secrets
functions/.env
functions/.env.local
functions/.env.production

# Node modules (for Firebase functions)
**/node_modules/
functions/.runtimeconfig.json
android/app/*.keystore
android/build/
android/.gradle/
