rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper function to check if the authenticated user has media/admin access
    // Media users can view any customer's data for content creation purposes
    function hasMediaAccess() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_role in ['media', 'dealer', 'admin'];
    }

    // Helper function to check if user can read another user's data
    // Either the owner OR a user with media access privileges
    function canReadUserData(userId) {
      return isOwner(userId) || hasMediaAccess();
    }

    // Helper function to check if the requester is the paired Lumina Bridge
    // for a given user. The bridge authenticates with its own Firebase account
    // (e.g. bridge@lumina.local) whose email is stored in the user doc during
    // pairing. This grants the bridge read/write on commands and bridge_status.
    function isBridgeForUser(userId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(userId)) &&
             get(/databases/$(database)/documents/users/$(userId)).data.bridge_email == request.auth.token.email;
    }

    // SECURITY: Prevent tampering with critical fields
    function cannotModifyCriticalFields() {
      return request.resource.data.owner_id == resource.data.owner_id &&
             request.resource.data.id == resource.data.id &&
             request.resource.data.email.lower() == resource.data.email.lower();
    }

    // SECURITY: Validate dealer email is from authorized domain
    function isValidDealerEmail(email) {
      // Only allow emails from verified dealer domains
      // Update this list with your authorized dealer domains
      return email == null ||
             email.matches('.*@nexgenled.com') ||
             email.matches('.*@authorized-dealer.com');
    }

    // Helper function to check if user is a primary user of any installation
    function isPrimaryUser() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.installation_role == 'primary';
    }

    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.installation_role == 'admin';
    }

    // Helper function to check if user has the corporate `user_role == 'admin'`
    // role. Distinct from isAdmin() above, which checks installation_role.
    // user_role admin gates corporate-managed catalogs (brand library, dealer
    // catalog, etc.).
    function isUserRoleAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('user_role', '') == 'admin';
    }

    // Helper function for corporate-level access WITHOUT including dealer
    // role. Distinct from hasMediaAccess() (which includes 'dealer') and
    // isUserRoleAdmin() (which excludes 'media'). Used by rule branches
    // that want global read for reporting/audit purposes (corporate +
    // marketing) but should NOT grant cross-dealer visibility to dealer
    // accounts. See referral_payouts read rule below for the canonical
    // use case.
    function isMediaOrAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('user_role', '') in ['media', 'admin'];
    }

    // Helper function to check whether the caller is authenticated via a
    // staff custom token minted by the mintStaffToken Cloud Function and
    // has a dealerCode claim matching the supplied value. Custom claims
    // are exposed as top-level fields on request.auth.token; .get() with
    // a default keeps the rule from erroring when the claim is missing.
    function hasStaffClaim(dealerCode) {
      return request.auth != null
        && request.auth.token.get('dealerCode', '') == dealerCode
        && (request.auth.token.get('role', '') == 'salesperson'
            || request.auth.token.get('role', '') == 'installer');
    }

    // Caller-only check: the staff custom token has role: 'admin'.
    // Distinct from isAdmin() above (which checks installation_role on
    // the user doc) — different identity, different concept. Admin-claim
    // sessions come from mintStaffToken's admin branch and grant
    // cross-dealer reads on dealer-scoped collections (the corporate
    // dashboard's surface area).
    function hasAdminClaim() {
      return request.auth != null
        && request.auth.token.get('role', '') == 'admin';
    }

    // Caller-only check: the staff custom token has role: 'owner'.
    // Owner is the cross-dealer god-mode role minted by mintStaffToken's
    // owner branch (master_corporate_pin). Owner sessions have NO
    // dealerCode claim — that's how rule helpers distinguish "scoped
    // staff" from "unscoped owner".
    //
    // Distinct from isOwner(userId) above (path-ownership check) — one
    // takes a userId path arg, this is no-arg and checks the role claim.
    function hasOwnerClaim() {
      return request.auth != null
        && request.auth.token.get('role', '') == 'owner';
    }

    // Convenience: caller has admin OR owner claim. Used widely for
    // cross-dealer read access on dealer-scoped collections (admin can
    // see everything for support / audit; owner can do everything).
    //
    // Caller-only check (no resource.data references), so safe for both
    // get and list queries — no query-shape constraints required.
    function hasAdminOrOwnerClaim() {
      return hasAdminClaim() || hasOwnerClaim();
    }

    // Helper function to check if user belongs to a specific installation
    function belongsToInstallation(installationId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.installation_id == installationId;
    }

    // Helper function to check if user is the primary user of a specific installation
    function isPrimaryUserOfInstallation(installationId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/installations/$(installationId)) &&
             get(/databases/$(database)/documents/installations/$(installationId)).data.primary_user_id == request.auth.uid;
    }

    // User profiles - private to each user, but readable by media/dealer/admin roles
    match /users/{userId} {
      // Media users can read any user profile for content creation
      allow read: if canReadUserData(userId);

      // SECURITY: On create, enforce owner_id matches auth uid
      // OR any authenticated user (installer setup creates customer profiles;
      // PIN validation happens app-side)
      allow create: if (isOwner(userId) &&
                      request.resource.data.owner_id == userId &&
                      request.resource.data.id == userId &&
                      isValidDealerEmail(request.resource.data.get('dealer_email', null)))
                    || request.auth != null;

      // SECURITY: On update, prevent tampering with critical fields
      // OR any authenticated user (installer setup updates customer profiles)
      allow update: if (isOwner(userId) &&
                      cannotModifyCriticalFields() &&
                      isValidDealerEmail(request.resource.data.get('dealer_email', null)))
                    || request.auth != null;

      allow delete: if isOwner(userId);

      // SECURITY: AI usage tracking subcollection
      match /ai_usage/{usageId} {
        // Users can read their own usage data
        allow read: if isOwner(userId);

        // Users can create usage events (logged by client)
        allow create: if isOwner(userId) &&
          request.resource.data.keys().hasAll(['timestamp', 'status']);

        // No updates or deletes (usage is append-only for auditing)
        allow update, delete: if false;
      }

      // Controllers subcollection - WLED devices registered to user
      match /controllers/{controllerId} {
        // Users can read their own controllers, media users can view for content.
        // Any authenticated user can also read — the installer wizard migrates
        // controllers from the anonymous UID to the customer UID, which requires
        // reading the source collection under a different user's path.
        allow read: if canReadUserData(userId) || request.auth != null;

        // Users can create controllers (from device discovery/setup).
        // Any authenticated user can create — the installer wizard adds
        // controllers under the customer's UID during the setup flow,
        // and the installer is signed in as an anonymous/different user.
        allow create: if request.auth != null;

        // Users can update their controllers (rename, IP changes, etc.)
        allow update: if isOwner(userId) || request.auth != null;

        // Users can delete their controllers. Any authenticated user is
        // allowed so the installer can clean up duplicates during setup.
        allow delete: if isOwner(userId) || request.auth != null;
      }

      // NOTE: Schedules are stored as an array field on the /users/{userId}
      // document (not a subcollection). The user document update rule above
      // governs schedule persistence. No subcollection rules needed.

      // Commands subcollection - Cloud Relay commands for remote WLED control
      match /commands/{commandId} {
        // Users can read their own commands; bridge reads to pick up pending commands
        allow read: if canReadUserData(userId) || isBridgeForUser(userId);

        // Users can create commands (sent from app when remote)
        allow create: if isOwner(userId);

        // Users or bridge can update commands (bridge sets status to completed/failed)
        allow update: if isOwner(userId) || isBridgeForUser(userId);

        // Users can delete commands (cleanup)
        allow delete: if isOwner(userId);
      }

      // Bridge status subcollection - heartbeat and status from ESP32 bridge
      match /bridge_status/{docId} {
        // Users can read their own bridge status; bridge reads for self-check
        allow read: if canReadUserData(userId) || isBridgeForUser(userId);

        // Bridge writes heartbeat (authenticated with its own Firebase account)
        allow create, update: if isOwner(userId) || isBridgeForUser(userId);

        // Allow cleanup
        allow delete: if isOwner(userId);
      }

      // Geofences subcollection - location-based automation triggers
      match /geofences/{geofenceId} {
        // Users can read their own geofences, media users can view for content
        allow read: if canReadUserData(userId);

        // Users can create geofences
        allow create: if isOwner(userId);

        // Users can update their geofences
        allow update: if isOwner(userId);

        // Users can delete their geofences
        allow delete: if isOwner(userId);
      }

      // Properties subcollection - user's properties (homes, locations)
      match /properties/{propertyId} {
        // Users can read their own properties, media users can view for content
        allow read: if canReadUserData(userId);

        // Users can create properties
        allow create: if isOwner(userId);

        // Users can update their properties
        allow update: if isOwner(userId);

        // Users can delete their properties
        allow delete: if isOwner(userId);
      }

      // Roofline Configuration subcollection - multi-segment roofline trace data
      // Written by RooflineEditorScreen when the user saves their traced
      // roofline, and by the legacy migration provider. Single doc at
      // /users/{userId}/roofline_config/config.
      match /roofline_config/{configId} {
        allow read: if canReadUserData(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Game Day Autopilot subcollection - per-team autopilot configs
      // (one doc per team slug, e.g. "atlanta-braves"). Written by the
      // GameDayAutopilotNotifier when the user toggles the Autopilot
      // switch on the Game Day team card. Without these rules the write
      // is denied silently and the toggle appears unresponsive.
      match /game_day_autopilot/{configId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Referrals subcollection - tracks people the user has referred.
      // Read by ambassadorTierProvider and the rewards-tracking stream in
      // the Refer & Earn screen. Written by ReferralAttributionService when
      // a new prospect signs up with this user's code, and by Cloud Functions
      // (referralPipelineService) on status transitions.
      match /referrals/{referralId} {
        // Owner can read their own referrals; dealers/admins can see all referrals
        allow read: if canReadUserData(userId);

        // Any authenticated user can create a referral doc here — the
        // ReferralAttributionService writes to the *referrer's* subcollection
        // from the *prospect's* signup flow, so the writer is not the doc owner.
        allow create: if request.auth != null;

        // Owner or any authenticated user (Cloud Functions / dealer flows
        // updating status) can update.
        allow update: if request.auth != null;

        // Only owner can delete
        allow delete: if isOwner(userId);
      }

      // Brand Profile subcollection - per-business commercial brand profile
      // derived from the global /brand_library. Stored as a subcollection
      // (typically the single doc id `brand`) to avoid colliding with the
      // existing `commercial_profile` map field on the user doc, which holds
      // hours, channels, teams, and day-parts from CommercialOnboardingWizard.
      match /brand_profile/{docId} {
        // Owner can read; media/dealer/admin roles can read for support and
        // content creation, mirroring properties/controllers visibility.
        allow read: if canReadUserData(userId);

        // Owner can write. Corporate user_role admins can also write so
        // brand-library corrections approved by corporate can be propagated
        // back into per-customer profiles when needed.
        allow write: if isOwner(userId) || isUserRoleAdmin();
      }

      // Commercial Events subcollection - sales/marketing events that
      // automatically activate a brand-aligned lighting design over a
      // date range. Owner-only — no media/dealer visibility (treated as
      // private business calendar data).
      match /commercial_events/{eventId} {
        allow read, create, update, delete: if isOwner(userId);
      }
    }

    // ── Bridge Registry (self-registration for Lumina ESP32 bridges) ──
    // The bridge writes /bridge_registry/{deviceId} on boot so the app
    // can discover and pair it via Firestore — no mDNS or local IP needed.
    // The bridge authenticates as bridge@nex-genled.com (single shared
    // account; per-bridge accounts are tracked as a future improvement).
    match /bridge_registry/{deviceId} {
      function isBridge() {
        return request.auth != null &&
               request.auth.token.email == 'bridge@nex-genled.com';
      }

      // Any signed-in user can read so the discovery flow can list
      // unpaired bridges and look up a specific bridge by deviceId.
      allow read: if request.auth != null;

      // Only the bridge can create its own registration doc.
      allow create: if isBridge();

      // Two write paths:
      //   (a) the bridge updates anything on its own doc, or
      //   (b) a user requests pairing by writing pendingUid=their uid
      //       — but only when the bridge is unpaired, so a malicious
      //       user can't yank a bridge that's already in service.
      allow update: if isBridge() ||
        (request.auth != null &&
         resource.data.status == 'unpaired' &&
         request.resource.data.pendingUid == request.auth.uid);

      // Registry docs are durable identifiers — never deleted by clients.
      allow delete: if false;
    }

    // ── Referral Codes (reverse lookup: code → uid) ──
    // Populated by the assignReferralCode Cloud Function on user create,
    // and by client-side fallback in referral_program_screen.dart for
    // legacy users whose user doc is missing the referralCode field.
    match /referral_codes/{code} {
      // Any authenticated user can read (validateCode in signup flow)
      allow read: if request.auth != null;

      // Self-claim: a user may create a code entry only if it points to
      // their own uid. Existence check before claim is enforced via
      // Firestore transaction in the client to avoid collisions.
      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid;

      // No client-side updates or deletes — only Cloud Functions/admin
      allow update, delete: if false;
    }
    
    // Sites - private to each user
    match /sites/{siteId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.owner_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.owner_id;
    }
    
    // Device configurations - private to each user
    match /devices/{deviceId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.owner_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.owner_id;
    }

    // ==================== Learning System Collections ====================

    // Pattern Usage Tracking - append-only logs with retention
    match /users/{userId}/pattern_usage/{usageId} {
      // Users can read their own usage data
      allow read: if isOwner(userId);

      // Users can create usage events
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['created_at', 'source']) &&
        request.resource.data.created_at is timestamp &&
        request.resource.data.source is string;

      // SECURITY: Allow deletion only for old records (90+ days for retention policy)
      // This allows cleanup functions to work
      allow delete: if isOwner(userId) &&
        resource.data.created_at < request.time - duration.value(90, 'd');

      // No updates (usage is append-only for auditing)
      allow update: if false;
    }

    // Favorites Collection
    match /users/{userId}/favorites/{favoriteId} {
      // Users can read their own favorites
      allow read: if isOwner(userId);

      // Users can create favorites
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['pattern_name', 'added_at']) &&
        request.resource.data.pattern_name is string &&
        request.resource.data.added_at is timestamp;

      // Users can update their favorites (usage count, last_used)
      allow update: if isOwner(userId) &&
        request.resource.data.pattern_name == resource.data.pattern_name &&
        request.resource.data.added_at == resource.data.added_at;

      // Users can delete their favorites
      allow delete: if isOwner(userId);
    }

    // Smart Suggestions Collection
    match /users/{userId}/suggestions/{suggestionId} {
      // Users can read their own suggestions
      allow read: if isOwner(userId);

      // Users can create suggestions (from client-side learning)
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['created_at', 'type', 'title']) &&
        request.resource.data.created_at is timestamp;

      // Users can update to dismiss suggestions
      allow update: if isOwner(userId) &&
        request.resource.data.dismissed == true;

      // Users can delete old suggestions
      allow delete: if isOwner(userId);
    }

    // Detected Habits Collection
    match /users/{userId}/detected_habits/{habitId} {
      // Users can read their detected habits
      allow read: if isOwner(userId);

      // Users can create habits (from client-side analysis)
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['detected_at', 'type', 'description']) &&
        request.resource.data.detected_at is timestamp;

      // No updates (habits are immutable once detected)
      allow update: if false;

      // SECURITY: Allow deletion for old habits (90+ days for retention policy)
      allow delete: if isOwner(userId) &&
        resource.data.detected_at < request.time - duration.value(90, 'd');
    }

    // Pattern Feedback subcollection (user's own feedback)
    match /users/{userId}/pattern_feedback/{feedbackId} {
      // Users can read their own feedback
      allow read: if isOwner(userId);

      // Users can create feedback
      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasAll(['pattern_name', 'rating', 'created_at']) &&
        request.resource.data.rating is int &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;

      // No updates or deletes (feedback is append-only for consistency)
      allow update, delete: if false;
    }

    // ==================== Global Analytics Collections ====================
    // These collections aggregate anonymized data across all users

    // Global Pattern Statistics
    match /analytics/global_pattern_stats/patterns/{patternId} {
      // Anyone can read trending patterns (public data)
      allow read: if request.auth != null;

      // Authenticated users can contribute stats (increment counters)
      allow create, update: if request.auth != null &&
        request.resource.data.keys().hasAll(['pattern_name', 'total_applications']);

      // No deletes (only Cloud Functions can clean up)
      allow delete: if false;

      // User tracking subcollection (hashed IDs for uniqueness)
      match /users/{hashedUserId} {
        allow read: if false; // Private tracking data
        allow write: if request.auth != null; // Any auth user can update
        allow delete: if false;
      }
    }

    // Pattern Feedback Aggregation
    match /analytics/pattern_feedback/patterns/{patternId} {
      // Anyone can read feedback stats
      allow read: if request.auth != null;

      // Authenticated users can contribute feedback
      allow create, update: if request.auth != null &&
        request.resource.data.keys().hasAll(['pattern_name', 'total_ratings']);

      allow delete: if false;

      // Anonymous rater tracking
      match /raters/{hashedUserId} {
        allow read: if false;
        allow write: if request.auth != null;
        allow delete: if false;
      }
    }

    // Pattern Requests
    match /analytics/pattern_requests/requests/{requestId} {
      // Anyone can read pattern requests
      allow read: if request.auth != null;

      // Authenticated users can create requests
      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll(['requested_theme', 'created_at', 'vote_count', 'fulfilled']) &&
        request.resource.data.vote_count == 1 &&
        request.resource.data.fulfilled == false;

      // Users can vote (increment vote_count)
      allow update: if request.auth != null &&
        request.resource.data.vote_count == resource.data.vote_count + 1;

      // No deletes (only admins via Cloud Functions)
      allow delete: if false;

      // Voter tracking
      match /voters/{hashedUserId} {
        allow read: if false;
        allow write: if request.auth != null;
        allow delete: if false;
      }
    }

    // Color Trends
    match /analytics/color_trends/weekly/{weekId} {
      // Anyone can read color trends
      allow read: if request.auth != null;

      // Authenticated users can contribute color usage
      allow create, update: if request.auth != null;

      allow delete: if false;
    }

    // Effect Popularity
    match /analytics/effect_popularity/effects/{effectId} {
      // Anyone can read effect popularity
      allow read: if request.auth != null;

      // Authenticated users can contribute effect usage
      allow create, update: if request.auth != null &&
        request.resource.data.keys().hasAll(['effect_id', 'usage_count']);

      allow delete: if false;
    }

    // Trending Reports (generated by Cloud Functions)
    match /analytics/trending_reports/{reportId} {
      // Anyone can read reports
      allow read: if request.auth != null;

      // Only Cloud Functions can create reports
      allow write: if false;
    }

    // SECURITY: OAuth codes and refresh tokens collections (server-side only)
    match /oauth_codes/{codeId} {
      allow read, write: if false; // Only Cloud Functions can access
    }

    match /oauth_refresh_tokens/{tokenId} {
      allow read, write: if false; // Only Cloud Functions can access
    }

    // ==================== Installer Mode Collections ====================

    // Dealers collection - managed by admins
    match /dealers/{dealerCode} {
      // Authenticated users can read dealers (for validation during installer login)
      allow read: if request.auth != null || hasAdminOrOwnerClaim();

      // Existing user_role admin path — preserved so corporate-admin
      // dealer management UI keeps working pre-corporate-migration.
      function isUserRoleAdminWithMedia() {
        return hasMediaAccess() &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_role == 'admin';
      }

      // Create + delete: admin-or-owner staff claim, OR existing
      // user_role admin path
      allow create: if isUserRoleAdminWithMedia() || hasAdminOrOwnerClaim();
      allow delete: if isUserRoleAdminWithMedia() || hasAdminOrOwnerClaim();

      // Update: admin-or-owner-staff and existing user_role admins can
      // update non-isActive fields. isActive flips require owner — a
      // dealer activation/deactivation is a privilege boundary worth
      // gating to the highest role.
      allow update: if (
        (isUserRoleAdminWithMedia() || hasAdminOrOwnerClaim()) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isActive'])
      ) || hasOwnerClaim();
    }

    // Installers collection - managed by dealers/admins
    match /installers/{installerId} {
      function isDealerAdmin() {
        return request.auth != null &&
               exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('user_role', '') in ['dealer', 'admin'];
      }

      // Detects whether an update is flipping the role TO or FROM 'admin'.
      // Both directions count as a role flip — promoting an installer to
      // admin is a privilege escalation (owner-only), and demoting an
      // existing admin is a privilege downgrade that should also be
      // owner-gated (auditability + protect against takeover).
      //
      // .get('role', '') keeps the rule from erroring on docs created
      // before the role field existed.
      function isRoleFlipToFromAdmin() {
        return request.resource.data.get('role', '') != resource.data.get('role', '') &&
               (request.resource.data.get('role', '') == 'admin' ||
                resource.data.get('role', '') == 'admin');
      }

      // Authenticated users can read installers (for PIN validation)
      allow read: if request.auth != null || hasAdminOrOwnerClaim();

      // Create/delete: existing dealer-admin path, plus admin/owner claims
      allow create, delete: if isDealerAdmin() || hasAdminOrOwnerClaim();

      // Update: dealer-admin or admin-claim sessions can update non-role-
      // flipping changes; role flips to/from 'admin' require owner.
      allow update: if (
        (isDealerAdmin() || hasAdminOrOwnerClaim()) &&
        !isRoleFlipToFromAdmin()
      ) || hasOwnerClaim();
    }

    // Installation records - created during customer setup
    match /installations/{installationId} {
      // Users who belong to this installation can read it, plus media/dealer/admin
      allow read: if belongsToInstallation(installationId) || hasMediaAccess() || isAdmin()
                    || request.auth != null
                    || hasAdminOrOwnerClaim();

      // Authenticated users with installer PIN validation (app-side) can create installations
      // PIN validation happens in-app before reaching this point
      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll(['primary_user_id', 'dealer_code', 'installer_code', 'installed_at']);

      // Primary users of this installation can update it, plus admins
      allow update: if isPrimaryUserOfInstallation(installationId) || isAdmin();

      // Only admins can delete installations
      allow delete: if isAdmin();

      // Sub-users subcollection - managed by primary users
      match /subUsers/{subUserId} {
        // Anyone in the installation can read sub-users list
        allow read: if belongsToInstallation(installationId) || hasMediaAccess();

        // Primary users of this installation can manage sub-users
        allow create, update, delete: if isPrimaryUserOfInstallation(installationId) || isAdmin();
      }
    }

    // ==================== Invitations Collection ====================

    // Invitations - for inviting sub-users to join an installation
    match /invitations/{invitationId} {
      // Primary user who created the invitation can read it
      // Invitee (by email) can also read it to accept
      allow read: if request.auth != null && (
        resource.data.primary_user_id == request.auth.uid ||
        resource.data.invitee_email == request.auth.token.email ||
        isAdmin()
      );

      // Primary users can create invitations for their installation
      allow create: if request.auth != null && isPrimaryUser() &&
        request.resource.data.keys().hasAll(['installation_id', 'primary_user_id', 'invitee_email', 'token', 'expires_at', 'status', 'permissions']) &&
        request.resource.data.primary_user_id == request.auth.uid &&
        request.resource.data.status == 'pending';

      // Invitee can update (accept) the invitation
      // Primary user can update (revoke) the invitation
      allow update: if request.auth != null && (
        resource.data.invitee_email == request.auth.token.email ||
        resource.data.primary_user_id == request.auth.uid ||
        isAdmin()
      );

      // Primary user can delete their invitations
      allow delete: if request.auth != null && (
        resource.data.primary_user_id == request.auth.uid ||
        isAdmin()
      );
    }

    // ── Installation Records (installer activity tracking) ──
    match /installation_records/{recordId} {
      // Authenticated users can create records during installer setup (PIN validated app-side)
      allow create: if request.auth != null;
      // Installers and admins can read records
      allow read: if request.auth != null || hasAdminOrOwnerClaim();
      // Only admins can update or delete
      allow update, delete: if isAdmin() || hasAdminOrOwnerClaim();
    }

    // ── Referral Payouts ──────────────────────────────────────
    //
    // Read scoping (post-2026-05-05):
    //   • referrer reads own payouts (referrerUid match)
    //   • dealer reads payouts for their own dealerCode (users.dealer_code
    //     or users.installer_dealer_code match resource.data.dealerCode)
    //   • staff custom-token sessions read payouts for their dealerCode
    //     claim (mintStaffToken)
    //   • media + admin (NOT dealer) read globally for corporate
    //     reporting / audit
    //
    // Closed in this rule revision: the previous rule used
    // hasMediaAccess() for global read, which includes the 'dealer'
    // role and let any dealer read every other dealer's payouts.
    // Replaced with isMediaOrAdmin() which excludes 'dealer'.
    //
    // Requires: payout docs MUST have `dealerCode` field. The model
    // change in commit 3bbb6da adds this for new writes; the backfill
    // script in 89b9880 populates it for legacy docs. Rule deploy to
    // production must be sequenced AFTER the backfill runs there.
    match /referral_payouts/{payoutId} {
      allow read: if request.auth != null && (
        resource.data.referrerUid == request.auth.uid ||
        (resource.data.dealerCode != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == resource.data.dealerCode) ||
        (resource.data.dealerCode != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('installer_dealer_code', '') == resource.data.dealerCode) ||
        hasStaffClaim(resource.data.dealerCode) ||
        isMediaOrAdmin() ||
        hasAdminOrOwnerClaim()
      );
      // Only dealers/admins can create or update payouts. Write scoping
      // intentionally NOT tightened in this commit — the writers today
      // are dealer/media/admin via in-app flows, and constraining them
      // to per-dealer scope would require auditing every write site.
      // Tracked as a follow-up if cross-dealer write becomes a concern.
      allow create: if hasMediaAccess();
      allow update: if hasMediaAccess();
      // Only admins can delete
      allow delete: if isAdmin();
    }

    // ── Dealer Demo Codes (public read for pre-auth validation) ──
    match /dealer_demo_codes/{codeId} {
      allow read: if true;
      allow write: if false; // Only admins via Firebase console
    }

    // ── Demo Leads (pre-auth lead capture) ──
    match /demo_leads/{leadId} {
      allow create: if true;
      allow read, update: if request.auth != null || true; // Leads may be read/updated during demo flow before auth
      allow delete: if false; // Only admins via Firebase console
    }

    // ── Demo Analytics (pre-auth event logging) ──
    match /demo_analytics/{eventId} {
      allow create: if true;
      allow read: if false; // Only Cloud Functions / console
      allow update, delete: if false;
    }

    // ── Email Notifications (triggered by demo lead submission) ──
    match /email_notifications/{notifId} {
      allow create: if true;
      allow read, update, delete: if false; // Only Cloud Functions
    }

    // ── App Configuration (PIN hashes, feature flags) ──
    //
    // Each doc gets its own rule. The catch-all at the bottom is
    // default-deny so adding a new app_config doc requires an explicit
    // rule — preventing accidental loosening by future code that just
    // writes to a new docId.
    //
    // IMPORTANT (Firestore rule semantics): Firestore rules are
    // permissive — if multiple match blocks match a path, ANY of them
    // granting access wins. A loose catch-all OR'd over a tight specific
    // rule = the loose catch-all leaks. The catch-all here is therefore
    // default-DENY (`allow read, write: if false;`) so the specific
    // rules above it are the actual gate.

    // Master PIN docs — admin/owner read, owner-only write.
    // Closes the offline-brute-force vector against PIN hashes:
    // mintStaffToken (Cloud Function via admin SDK) bypasses these
    // rules; client code reads only via admin/owner staff sessions.
    match /app_config/master_sales_pin {
      allow read: if hasAdminOrOwnerClaim();
      allow write: if hasOwnerClaim();
    }
    match /app_config/master_installer {
      allow read: if hasAdminOrOwnerClaim();
      allow write: if hasOwnerClaim();
    }
    match /app_config/master_admin {
      allow read: if hasAdminOrOwnerClaim();
      allow write: if hasOwnerClaim();
    }

    // master_corporate_pin: tightened to admin/owner read on
    // 2026-05-05 once the CorporateModeNotifier migrated to
    // mintStaffToken's owner mode (commit 8-iii). The doc is no longer
    // read by any client code — only the admin SDK (Cloud Function via
    // mintStaffToken) and admin/owner staff sessions for the corporate
    // PIN management UI.
    match /app_config/master_corporate_pin {
      allow read: if hasAdminOrOwnerClaim();
      allow write: if hasOwnerClaim();
    }

    // Network announcements — admin/owner read, owner write.
    // Both the doc itself and its `items` subcollection.
    match /app_config/announcements {
      allow read: if hasAdminOrOwnerClaim();
      allow write: if hasOwnerClaim();
    }
    match /app_config/announcements/items/{itemId} {
      allow read: if hasAdminOrOwnerClaim();
      allow write: if hasOwnerClaim();
    }

    // Pricing defaults — broadly readable (clients fall back to this
    // when a dealer has no per-dealer pricing). Writes are still gated
    // to legacy installation_role admin pending corporate migration —
    // tighten to hasOwnerClaim() in 8-iii.
    match /app_config/pricing_defaults {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && isAdmin()) || hasOwnerClaim();
    }

    // Catch-all: any other app_config doc that doesn't have an explicit
    // rule above is default-deny. New app_config docs MUST add their own
    // rule — failing closed prevents future code from accidentally
    // creating an unprotected configuration surface.
    match /app_config/{docId} {
      allow read, write: if false;
    }

    // ── Sales Jobs ───────────────────────────────────────────────
    match /sales_jobs/{jobId} {
      function isJobStakeholder() {
        return request.auth != null && (
          hasMediaAccess() ||
          (resource != null &&
           resource.data.dealerCode != null &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == resource.data.dealerCode) ||
          (resource != null &&
           resource.data.dealerCode != null &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('installer_dealer_code', '') == resource.data.dealerCode) ||
          (resource != null &&
           resource.data.dealerCode != null &&
           hasStaffClaim(resource.data.dealerCode))
        );
      }

      allow read: if request.auth != null && (isJobStakeholder() || hasMediaAccess() || hasAdminOrOwnerClaim());
      allow create: if request.auth != null;
      allow update: if request.auth != null && (isJobStakeholder() || hasMediaAccess() || hasAdminOrOwnerClaim());
      allow delete: if false;

      // Material list — single document per job
      match /materialList/{docId} {
        allow read, write: if request.auth != null;
      }

      // Material ledger — append-only audit trail
      match /materialLedger/{entryId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // ── Dealer Material Catalog ──────────────────────────────────
    match /dealers/{dealerCode}/materialCatalog/{itemId} {
      allow read: if request.auth != null || hasAdminOrOwnerClaim();
      allow write: if (hasMediaAccess() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_role == 'admin')
        || hasAdminOrOwnerClaim();
    }

    // ── Dealer Inventory ─────────────────────────────────────────
    match /dealers/{dealerCode}/inventory/{itemId} {
      function isDealerMember() {
        return request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == dealerCode ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('installer_dealer_code', '') == dealerCode ||
          hasMediaAccess() ||
          hasStaffClaim(dealerCode) ||
          hasAdminOrOwnerClaim()
        );
      }
      allow read, write: if isDealerMember();
    }

    // ── Dealer Inventory Ledger (append-only) ────────────────────
    match /dealers/{dealerCode}/inventoryLedger/{entryId} {
      function isDealerMember() {
        return request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == dealerCode ||
          hasMediaAccess()
        );
      }
      // Staff-claim and admin/owner-claim read access are inlined here
      // (not in isDealerMember) so the create rule below stays gated by
      // user-doc membership only.
      allow read: if isDealerMember() || hasStaffClaim(dealerCode) || hasAdminOrOwnerClaim();
      allow create: if isDealerMember();
      allow update, delete: if false;
    }

    // ── Dealer SKU Inventory ─────────────────────────────────────
    // Per-dealer warehouse stock keyed by /product_catalog/{sku}.
    // Distinct from /dealers/{dealerCode}/inventory above which is
    // materialId-keyed and tracks per-job material commitments
    // (Day-1/Day-2 install material checkout flow). This new path
    // is the SKU-level "what's physically on the shelf" surface
    // for the ordering pipeline.
    //
    // Schema: in_warehouse, reserved, on_truck, on_order,
    //         needed (computed), reorder_threshold,
    //         auto_reorder_enabled, auto_reorder_qty, last_updated.
    match /dealers/{dealerCode}/sku_inventory/{sku} {
      function isDealerMember() {
        return request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == dealerCode ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('installer_dealer_code', '') == dealerCode ||
          hasMediaAccess() ||
          hasStaffClaim(dealerCode) ||
          hasAdminOrOwnerClaim()
        );
      }
      allow read, write: if isDealerMember();
    }

    // ── Dealer Shipping Address ──────────────────────────────────
    // Per-dealer shipping address used as the ship-to on every
    // dealer_orders write. Canonical doc id is 'primary'; rule is
    // scoped to the subcollection so future expansion (additional
    // warehouses, return centers) doesn't require a rule change.
    match /dealers/{dealerCode}/shipping_address/{docId} {
      function isDealerMember() {
        return request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == dealerCode ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('installer_dealer_code', '') == dealerCode ||
          hasMediaAccess() ||
          hasStaffClaim(dealerCode) ||
          hasAdminOrOwnerClaim()
        );
      }
      allow read, write: if isDealerMember();
    }

    // ── Dealer Pricing ───────────────────────────────────────────
    match /dealers/{dealerCode}/pricing/{docId} {
      function isDealerMember() {
        return request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == dealerCode ||
          hasMediaAccess()
        );
      }
      // Staff-claim and admin/owner-claim read access are inlined here
      // (not in isDealerMember) so write stays gated by user-doc
      // membership only.
      allow read: if isDealerMember() || hasStaffClaim(dealerCode) || hasAdminOrOwnerClaim();
      allow write: if isDealerMember();
    }

    // ── Dealer Config (messaging templates, dealer-scoped settings) ──
    match /dealers/{dealerCode}/config/{docId} {
      function isDealerMember() {
        return request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == dealerCode ||
          hasMediaAccess()
        );
      }
      // Staff-claim and admin/owner-claim read access are inlined here
      // (not in isDealerMember) so write stays gated by user-doc
      // membership only.
      allow read: if isDealerMember() || hasStaffClaim(dealerCode) || hasAdminOrOwnerClaim();
      allow write: if isDealerMember();
    }

    // ==================== Neighborhood Sync (Block Party) ====================
    // Group documents live at /neighborhoods/{groupId}. The creator's uid is
    // stored as `creatorUid` and the full member list as `memberUids[]`.
    // Subcollections: members, commands, schedules, syncEvents, syncSessions,
    // game_day_autopilot.
    match /neighborhoods/{groupId} {
      // Helpers scoped to this group
      function isGroupMember() {
        return request.auth != null &&
               resource != null &&
               request.auth.uid in resource.data.memberUids;
      }

      function isGroupCreator() {
        return request.auth != null &&
               resource != null &&
               resource.data.creatorUid == request.auth.uid;
      }

      // Any authenticated user can read groups so they can:
      //   - list groups they belong to (memberUids contains-uid query)
      //   - look up a group by inviteCode when joining
      //   - discover nearby public groups
      allow read: if request.auth != null;

      // Only the authenticated creator may create a group, and they must
      // include themselves as creatorUid + first memberUids entry.
      allow create: if request.auth != null &&
                       request.resource.data.creatorUid == request.auth.uid &&
                       request.auth.uid in request.resource.data.memberUids;

      // Updates allowed for: creator (any field), or any authenticated user
      // joining/leaving (toggling memberUids only — enforced app-side).
      allow update: if request.auth != null && (
        isGroupCreator() ||
        isGroupMember() ||
        // Allow joining via invite code: writer adds themselves to memberUids
        request.auth.uid in request.resource.data.memberUids
      );

      // Only the creator may delete the group document.
      allow delete: if isGroupCreator();

      // Members subcollection: each member's local config (display name,
      // LED count, position, online status, participation).
      match /members/{memberUid} {
        // Any group member can read the member roster.
        allow read: if request.auth != null;

        // A user may create/update their own member doc. The creator may
        // also write any member doc (for reorder/host moderation).
        allow create, update: if request.auth != null && (
          request.auth.uid == memberUid ||
          get(/databases/$(database)/documents/neighborhoods/$(groupId)).data.creatorUid == request.auth.uid
        );

        // Members can remove themselves; creator can remove anyone.
        allow delete: if request.auth != null && (
          request.auth.uid == memberUid ||
          get(/databases/$(database)/documents/neighborhoods/$(groupId)).data.creatorUid == request.auth.uid
        );
      }

      // Sync commands broadcast to the group (host → all members).
      match /commands/{commandId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null;
      }

      // Schedules for recurring sync events.
      match /schedules/{scheduleId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null;
      }

      // One-off sync events (Block Party / Game Day setups).
      match /syncEvents/{eventId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null;
      }

      // Active sync sessions (per-event runtime state).
      match /syncSessions/{sessionId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null;
      }

      // Group autopilot config (game day automation).
      match /game_day_autopilot/{configId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null;
      }
    }

    // ── Brand Library ────────────────────────────────────────────
    // Global, corporate-curated catalog of business brands keyed by
    // brandId (e.g. "state-farm"). Seeded by Nex-Gen via the
    // scripts/seed_brand_library.js admin script and refined by
    // approved installer corrections. Read by every authenticated
    // user during the brand-search step in CommercialOnboardingWizard;
    // writes are restricted to corporate user_role admins.
    match /brand_library/{brandId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isUserRoleAdmin();
    }

    // ── Brand Library Corrections ────────────────────────────────
    // Installer/customer-submitted color corrections awaiting corporate
    // review. Submitter can read their own; corporate admins can read
    // and update all. Submitted docs are never deleted — corrections
    // are an audit trail (status field tracks lifecycle: pending →
    // approved/rejected; approved corrections set applied_to_library).
    match /brand_library_corrections/{correctionId} {
      allow read: if request.auth != null && (
        resource.data.submitted_by == request.auth.uid ||
        isUserRoleAdmin() ||
        hasAdminOrOwnerClaim()
      );

      // Authenticated users can create — but submitted_by must match the
      // writer's uid to prevent impersonation.
      allow create: if request.auth != null &&
                       request.resource.data.submitted_by == request.auth.uid;

      // Only corporate admins (legacy user_role) or staff admin/owner
      // claims can transition status / set reviewed_by / applied_to_library
      // on existing correction docs.
      allow update: if isUserRoleAdmin() || hasAdminOrOwnerClaim();

      // Audit trail — never deleted.
      allow delete: if false;
    }

    // ── Product Catalog (global) ─────────────────────────────────
    // Canonical Nex-Gen SKU catalog. Read by every authenticated
    // user (dealers browse it from the order screen and the
    // dealer inventory screen joins by sku); writes restricted to
    // corporate user_role admins (legacy path) and admin/owner
    // staff-claim sessions (catalog management screen).
    //
    // Distinct from per-dealer /dealers/{dealerCode}/materialCatalog
    // which is dealer-scoped job estimation data — both serve
    // different purposes, neither replaces the other.
    match /product_catalog/{sku} {
      allow read: if request.auth != null;
      allow create, update, delete: if isUserRoleAdmin() || hasAdminOrOwnerClaim();
    }

    // ── Dealer Orders ────────────────────────────────────────────
    // Top-level orders submitted by dealers to Nex-Gen corporate.
    // Status flow:
    //   draft → submitted → payment_pending → payment_confirmed
    //   → processing → shipped → received
    //
    // Stakeholder identity comes from any of:
    //   • users.dealer_code matches order.dealer_code
    //   • users.installer_dealer_code matches order.dealer_code
    //   • staff custom-token claim with dealerCode matching
    //     order.dealer_code (mintStaffToken)
    // Admin/owner staff sessions and corporate (media+admin) read
    // every dealer's orders for review/approval.
    match /dealer_orders/{orderId} {
      function isOrderStakeholder() {
        return request.auth != null && (
          (resource != null &&
           resource.data.dealer_code != null &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == resource.data.dealer_code) ||
          (resource != null &&
           resource.data.dealer_code != null &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('installer_dealer_code', '') == resource.data.dealer_code) ||
          (resource != null &&
           resource.data.dealer_code != null &&
           hasStaffClaim(resource.data.dealer_code))
        );
      }

      allow read: if isOrderStakeholder() || isMediaOrAdmin() || hasAdminOrOwnerClaim();

      // Create: dealer creates an order tagged with their own
      // dealer_code (verified via user-doc field or staff claim).
      // Admin/owner staff can also create on a dealer's behalf.
      allow create: if request.auth != null && (
        (request.resource.data.dealer_code != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dealer_code', '') == request.resource.data.dealer_code) ||
        (request.resource.data.dealer_code != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('installer_dealer_code', '') == request.resource.data.dealer_code) ||
        (request.resource.data.dealer_code != null &&
         hasStaffClaim(request.resource.data.dealer_code)) ||
        hasAdminOrOwnerClaim()
      );

      // Update: stakeholders update their own orders (status
      // transitions, notes, line-item edits while in draft).
      // Admin/owner update for approval, shipping cost entry,
      // payment confirmation, and shipping tracking. App-side
      // code enforces the state-machine integrity.
      allow update: if isOrderStakeholder() || isMediaOrAdmin() || hasAdminOrOwnerClaim();

      // Delete: only drafts. Submitted orders are an audit trail
      // for payment + shipping reconciliation and must never be
      // deleted from the client.
      allow delete: if (isOrderStakeholder() || hasAdminOrOwnerClaim()) &&
                     resource.data.status == 'draft';
    }

    // ── Corporate Inventory (Nex-Gen warehouse on-hand) ──────────
    // Top-level, admin/owner-only. Tracks Nex-Gen master warehouse
    // stock keyed by SKU. Decremented when dealer orders are
    // approved (reserved_for_orders); incremented when
    // /purchase_orders are received from suppliers.
    match /corporate_inventory/{sku} {
      allow read: if isUserRoleAdmin() || hasAdminOrOwnerClaim();
      allow create, update, delete: if isUserRoleAdmin() || hasAdminOrOwnerClaim();
    }

    // ── Purchase Orders (Nex-Gen → suppliers) ────────────────────
    // Tyler's inbound POs to Gouly et al. Status flow:
    //   ordered → partial → received
    // Admin/owner-only — no dealer or installer access. Receiving
    // a PO line-item increments /corporate_inventory.on_hand for
    // that SKU.
    match /purchase_orders/{poId} {
      allow read: if isUserRoleAdmin() || hasAdminOrOwnerClaim();
      allow create, update, delete: if isUserRoleAdmin() || hasAdminOrOwnerClaim();
    }

    // ──────────────────────────────────────────────────────────────────
    // Collection-group rules — for queries that traverse subcollections
    // across all dealers. The corporate dashboard's Warehouse tab uses
    // these to aggregate inventory and material catalog across the
    // entire dealer network.
    //
    // Per-doc rules (above, under /dealers/{dealerCode}/...) gate
    // single-doc and subcollection reads scoped to one dealer. The
    // collection-group rules below let admin/owner sessions list
    // across all dealers — without them, CG queries default-deny
    // even when the per-dealer rule would have allowed the read.
    // ──────────────────────────────────────────────────────────────────

    match /{path=**}/inventory/{itemId} {
      allow read: if hasAdminOrOwnerClaim();
    }

    match /{path=**}/sku_inventory/{itemId} {
      allow read: if hasAdminOrOwnerClaim();
    }

    match /{path=**}/materialCatalog/{itemId} {
      allow read: if hasAdminOrOwnerClaim();
    }
  }
}
